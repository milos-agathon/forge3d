    def to_dict(self) -> dict[str, Any]: ...

class FontFallbackRange:
    def __init__(self, name: str, start: int, end: int, font_family: str) -> None: ...
    def covers(self, char: str) -> bool: ...
    def to_dict(self) -> dict[str, Any]: ...

class FontAtlas:
    glyphs: set[str]
    def __init__(self, glyphs: set[str] = ..., font_size: int = ..., line_height: int = ..., baseline: int = ..., coverage: Mapping[str, Any] | None = ..., source_path: str | None = ..., fallbacks: Sequence[FontFallbackRange | Mapping[str, Any]] = ..., diagnostics: Sequence[Diagnostic | Mapping[str, Any]] = ...) -> None: ...
    @classmethod
    def default_latin(cls, *, fallbacks: Sequence[FontFallbackRange | Mapping[str, Any]] | None = ...) -> FontAtlas: ...
    @classmethod
    def from_font(cls, path: str | Path, *, ranges: Sequence[FontFallbackRange | Mapping[str, Any]] | None = ..., font_size: int = ..., line_height: int | None = ...) -> FontAtlas: ...
    def covers(self, char: str) -> bool: ...
    def fallback_for(self, char: str) -> FontFallbackRange | None: ...
    def validate_text(self, text: str, *, layer_id: str | None = ..., object_id: str | None = ...) -> list[Diagnostic]: ...
    def to_dict(self) -> dict[str, Any]: ...

class TypographySettings:
    def __init__(self, font_size: int = ..., kerning: bool = ..., tracking: float = ..., line_height: float | None = ..., multiline: bool = ..., callout: bool = ..., callout_offset: Sequence[float] = ..., halo_width_px: float = ..., halo_color: Sequence[float] | str | None = ...) -> None: ...
