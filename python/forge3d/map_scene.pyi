class CompiledScenePlan:
    recipe_hash: str
    camera_terrain_key: str
    label_plans: Mapping[str, Any]
    manifest: Any
    validation_report: ValidationReport
    def __init__(self, recipe_hash: str, camera_terrain_key: str, label_plans: Mapping[str, Any], manifest: Any, validation_report: ValidationReport) -> None: ...

class MapScene:
    recipe: SceneRecipe
    last_render_path: str | None
    last_render_backend: str | None
    last_render_metadata: dict[str, Any] | None
    compiled_label_plans: dict[str, Any]
    compiled_plan: CompiledScenePlan | None
    def __init__(self, recipe: SceneRecipe | None = ..., *, terrain: TerrainSource | None = ..., camera: OrbitCamera | None = ..., lighting: LightingPreset | None = ..., layers: Sequence[Any] | None = ..., output: OutputSpec | None = ..., target_crs: str | None = ..., map_furniture: MapFurnitureLayer | None = ..., render_policy: str = ..., diagnostics_policy: Mapping[str, Any] | None = ..., reproducibility_profile: ReproducibilityProfile | None = ...) -> None: ...
    def to_dict(self) -> dict[str, Any]: ...
    def alignment_report(self) -> dict[str, Any]: ...
    def material_vt_stats(self) -> dict[str, float] | None: ...
    @classmethod
    def load_bundle(cls, path: str | Path) -> MapScene: ...
    def validate(self) -> ValidationReport: ...
    def compile_plan(self) -> CompiledScenePlan: ...
    def render(
        self,
        path: str | None = ...,
        *,
        emit_provenance: bool = ...,
        provenance_signing_key: bytes | None = ...,
    ) -> ValidationReport: ...
    def save_bundle(self, path: str | Path) -> ValidationReport: ...

__all__: list[str]
