    def __init__(self, layer_id: str, path: PathLikeStr | None = ..., crs: str | None = ..., opacity: float = ..., metadata: Mapping[str, Any] | None = ...) -> None: ...
    def to_dict(self) -> dict[str, Any]: ...

class VectorOverlay:
